# Copy this file to .streamlit/secrets.toml (local) or paste values in Streamlit Cloud > App > Settings > Secrets.

GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"
GEMINI_CHAT_MODEL = "gemini-2.5-flash-lite"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-2-preview"
TOOLS_DOKUMEN_SPREADSHEET_ID = "YOUR_SPREADSHEET_ID"
TOOLS_DOKUMEN_SPREADSHEET_NAME = "tools_dokumen"
TOOLS_DOKUMEN_ADMIN_USERNAMES = "admin.username"
