# Local mode (copy to .env)
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_CHAT_MODEL="gemini-2.5-flash-lite"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2-preview"
TOOLS_DOKUMEN_SPREADSHEET_ID=""
TOOLS_DOKUMEN_SPREADSHEET_NAME="tools_dokumen"
TOOLS_DOKUMEN_ADMIN_USERNAMES=""
TOOLS_DOKUMEN_DLP_ENABLED="true"

# Optional (hybrid mode): isi JSON service account dalam 1 baris jika tidak memakai file static/credentials.json
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# Choose one local credentials method:
# 1) Place Google service account file at: static/credentials.json
# 2) Or set GOOGLE_SERVICE_ACCOUNT_JSON with compact one-line JSON string
#    (optional, only if you do not want to store a local file)
# GOOGLE_SERVICE_ACCOUNT_JSON="{\"type\":\"service_account\",...}"
